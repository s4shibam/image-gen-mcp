{
  "name": "image-gen-mcp",
  "version": "0.0.1",
  "description": "STDIO MCP server for OpenAI and Gemini image generation",
  "type": "module",
  "bin": {
    "image-gen-mcp": ".dist/index.js"
  },
  "files": [
    ".dist"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "image-generation",
    "openai",
    "gemini",
    "stdio"
  ],
  "author": "s4shibam",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s4shibam/image-gen-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/s4shibam/image-gen-mcp/issues"
  },
  "homepage": "https://github.com/s4shibam/image-gen-mcp#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@modelcontextprotocol/server": "^2.0.0-beta.4",
    "dotenv": "^17.4.2",
    "openai": "^6.48.0",
    "p-limit": "^7.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
